# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://fguvvhqvzifnsihhomcv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_pZW1i4cJYBWhRvIXA_tV5g_7RglHWF5
# Required for /api/invite/verify and /api/invite/consume (server-only). Dashboard → Settings → API → service_role secret.
# Without this, invite codes return 503 locally even if the code exists in Supabase.
# SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (for AI assistants). Create a key at https://console.anthropic.com/ and set only in .env.local — never commit real keys.
ANTHROPIC_API_KEY=

# ANISHA Phase E: allow AI summaries in My Alerts / evacuation map (also enable per user in Settings)
# NEXT_PUBLIC_ALERTS_AI=1

# NASA FIRMS (live fire feed). Optional: GET /api/flameo/context uses NIFC always; adds FIRMS when this is set.
NASA_FIRMS_API_KEY=

# ML Service (Modal or Render - optional, falls back to rule-based)
ML_SERVICE_URL=https://your-modal-app.modal.run

# App URL (for OAuth redirects and family invite links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Resend (https://resend.com) for My Family invite emails. Without this, invite links are logged server-side.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Wildfire <onboarding@resend.dev>
# Optional: plain minimal invite (h2 + link). Default is Minutes Matter branded HTML (matches confirmation email shell).
# RESEND_INVITE_EMAIL_STYLE=confirmation
